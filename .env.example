BOT_TOKEN=replace-with-telegram-bot-token

# Image backend (Google only)
IMAGE_BACKEND_PROVIDER=google
IMAGE_BACKEND_API_KEY=replace-with-google-ai-studio-api-key
IMAGE_BACKEND_BASE_URL=https://generativelanguage.googleapis.com/v1beta
IMAGE_BACKEND_MODEL=gemini-2.5-flash-image
IMAGE_BACKEND_EDIT_MODEL=gemini-3.1-flash-image-preview
IMAGE_BACKEND_TIMEOUT=60
IMAGE_BACKEND_PROXY_URL=

# Optional speech recognition backend
VSEGPT_API_KEY=
VSEGPT_BASE_URL=https://api.vsegpt.ru/v1
VSEGPT_STT_MODEL=stt-openai/whisper-1
VSEGPT_TIMEOUT=60

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=nanobanana
MYSQL_USERNAME=nanobanana
MYSQL_PASSWORD=replace-with-db-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Optional
SEP=\n
SET_COMMANDS_ON_STARTUP=true
