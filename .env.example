APP_ENV=dev
BOT_TOKEN=replace-with-telegram-bot-token

# Image backend
IMAGE_BACKEND_API_KEY=replace-with-image-backend-key
IMAGE_BACKEND_BASE_URL=https://example.com/api
IMAGE_BACKEND_TIMEOUT=60

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=nanobanana
MYSQL_USERNAME=nanobanana
MYSQL_PASSWORD=replace-with-db-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Optional
SEP=\n
SET_COMMANDS_ON_STARTUP=true
