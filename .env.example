BOT_TOKEN=replace-with-telegram-bot-token

# Image backend
IMAGE_BACKEND_API_KEY=replace-with-image-backend-key
IMAGE_BACKEND_BASE_URL=https://api.vsegpt.ru/v1
IMAGE_BACKEND_TIMEOUT=60
IMAGE_BACKEND_PROXY_URL=

# Optional fallback (used for speech recognition and image backend if IMAGE_BACKEND_API_KEY is empty)
VSEGPT_API_KEY=
VSEGPT_BASE_URL=https://api.vsegpt.ru/v1
VSEGPT_STT_MODEL=stt-openai/whisper-1
VSEGPT_TIMEOUT=60

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=nanobanana
MYSQL_USERNAME=nanobanana
MYSQL_PASSWORD=replace-with-db-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Optional
SEP=\n
SET_COMMANDS_ON_STARTUP=true
