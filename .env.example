BOT_TOKEN=replace-with-telegram-bot-token

# Image backend (Runware)
IMAGE_BACKEND_PROVIDER=runware
IMAGE_BACKEND_API_KEY=replace-with-runware-api-key
IMAGE_BACKEND_BASE_URL=https://api.runware.ai/v1
# Default model (google:4@1=Nano Banana, google:4@2=Nano Banana Pro, google:4@3=Nano Banana 2)
IMAGE_BACKEND_MODEL=google:4@1
IMAGE_BACKEND_TIMEOUT=120
IMAGE_BACKEND_TOTAL_TIMEOUT=150
IMAGE_BACKEND_RETRIES=1
IMAGE_BACKEND_RETRY_BACKOFF=2
IMAGE_BACKEND_RATE_LIMIT_RETRIES=1
IMAGE_BACKEND_RATE_LIMIT_BACKOFF=5
# If IMAGE_BACKEND_PROXY_URL is set, it overrides standard HTTP_PROXY/HTTPS_PROXY/ALL_PROXY.
# If it is empty, the bot uses standard proxy env vars automatically.
IMAGE_BACKEND_PROXY_URL=

# Optional speech recognition backend
VSEGPT_API_KEY=
VSEGPT_BASE_URL=https://api.vsegpt.ru/v1
VSEGPT_STT_MODEL=stt-openai/whisper-1
VSEGPT_TIMEOUT=60

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=nanobanana
MYSQL_USERNAME=nanobanana
MYSQL_PASSWORD=replace-with-db-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Optional
SEP=\n
SET_COMMANDS_ON_STARTUP=true

TOPUP_TARIFFS_CARD=30:149:30:30,65:299:65:65,170:690:170:170,270:990:270:270,540:1900:540:540

TOPUP_TARIFFS_STARS=149:149:30:30,299:299:65:65,690:690:170:170,990:990:270:270,1900:1900:540:540
